# Stellar / Soroban
CONTRACT_ID=
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK=testnet
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Runtime
NODE_ENV=development
PORT=4000

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
# JWT key rotation: set JWT_SECRET_PREVIOUS to the old secret during transition.
# Tokens signed with the previous secret remain valid until all users re-authenticate.
# Once the transition window has passed, remove JWT_SECRET_PREVIOUS to stop accepting old tokens.
# Rotation procedure:
#   1. Copy JWT_SECRET value into JWT_SECRET_PREVIOUS
#   2. Set JWT_SECRET to a new secret (openssl rand -hex 32)
#   3. Deploy — old tokens still work via JWT_SECRET_PREVIOUS
#   4. After all sessions expire, remove JWT_SECRET_PREVIOUS and redeploy
JWT_SECRET_PREVIOUS=
ADMIN_WALLET=
ADMIN_WALLETS=
ADMIN_THRESHOLD=1

# IPFS / Pinata
PINATA_API_KEY=
PINATA_SECRET=
PINATA_GATEWAY=https://gateway.pinata.cloud
# Comma-separated fallback IPFS gateways (defaults to Pinata/Cloudflare/ipfs.io when unset)
IPFS_GATEWAYS=
# TTL for IPFS pin dedup cache entries in milliseconds (default: 300000)
IPFS_PIN_CACHE_TTL_MS=300000

# Platform
PLATFORM_FEE_BPS=500
# Platform signing keypair (required in staging/production)
# Generate with: stellar keys generate --network testnet
PLATFORM_SECRET_KEY=
# Legacy platform secret used by src/utils/contract.ts
PLATFORM_SECRET=
# Logging
LOG_LEVEL=info
# Comma-separated exact paths that requestLogger will never log (probe/metrics suppression)
LOG_SKIP_PATHS=/health,/health/liveness,/health/readiness,/ready,/metrics
# Fraction of non-skipped requests to log (1 = all, 0.1 = ~10%). Useful for high-traffic paths.
LOG_SAMPLE_RATE=1

# Database
DB_PATH=scout-off.db

# Security headers (optional overrides)
SECURITY_HSTS=max-age=31536000; includeSubDomains
SECURITY_X_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_X_FRAME_OPTIONS=DENY
SECURITY_REFERRER_POLICY=no-referrer
SECURITY_CSP=default-src 'none'

# Feature flags
STELLAR_HEALTH_CHECK=true
JSON_PAYLOAD_LIMIT=1mb
# Response compression threshold in bytes (default: 1024)
COMPRESSION_THRESHOLD=1024

# Cache TTL for single-player and player-list lookups (milliseconds, default: 60000)
PLAYER_CACHE_TTL_MS=60000

# CORS
# Comma-separated list of allowed origins in staging/production.
# Falls back to * when NODE_ENV=development or this is not set.
ALLOWED_ORIGINS=

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Auth-specific rate limiting (brute-force protection on /auth/challenge and /auth/token)
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5

# Webhooks
WEBHOOK_ENABLED=false
WEBHOOK_URL=

# Security headers
SECURITY_HSTS=max-age=31536000; includeSubDomains
SECURITY_X_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_X_FRAME_OPTIONS=DENY
SECURITY_REFERRER_POLICY=no-referrer

# API versioning
API_PREFIX=/api
API_V=v1

# Metrics
METRICS_ENABLED=false

# Milestone rate limiting
MILESTONE_RATE_WINDOW_MS=60000
MILESTONE_RATE_MAX=10

# Redis (optional — used for distributed caching)
REDIS_URL=

# Proxy
TRUSTED_PROXY_COUNT=0

# Indexer
# Ledger to replay indexing from if it's earlier than the stored last_ledger (leave unset to disable)
INDEXER_BACKFILL_FROM_LEDGER=
# Number of ledgers behind tip before the indexer logs a lag warning (default: 100)
INDEXER_LAG_WARN_THRESHOLD=100

# Subscriptions
# Grace period in hours after expiry during which access is still granted (default: 24)
SUBSCRIPTION_GRACE_PERIOD_HOURS=24

# Requests
# Global request timeout in milliseconds before the server responds with 503 (default: 30000)
REQUEST_TIMEOUT_MS=30000

# Database
# Log queries slower than this threshold in milliseconds (default: 50)
SLOW_QUERY_THRESHOLD_MS=50

# Admin
# Comma-separated list of IPs/CIDRs allowed to access admin routes (leave unset to allow all)
ADMIN_IP_ALLOWLIST=

# Tracing (OpenTelemetry)
# OTLP exporter endpoint (leave unset to disable tracing export)
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=scout-off-backend
