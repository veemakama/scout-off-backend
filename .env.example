# Stellar / Soroban
CONTRACT_ID=
HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org
NETWORK=testnet
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Runtime
NODE_ENV=development
PORT=4000

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
ADMIN_WALLET=
ADMIN_WALLETS=
ADMIN_THRESHOLD=1

# IPFS / Pinata
PINATA_API_KEY=
PINATA_SECRET=
PINATA_GATEWAY=https://gateway.pinata.cloud

# Platform
PLATFORM_FEE_BPS=500
# Logging
LOG_LEVEL=info
# Comma-separated exact paths that requestLogger will never log (probe/metrics suppression)
LOG_SKIP_PATHS=/health,/health/liveness,/health/readiness,/ready,/metrics
# Fraction of non-skipped requests to log (1 = all, 0.1 = ~10%). Useful for high-traffic paths.
LOG_SAMPLE_RATE=1

# Database
DB_PATH=scout-off.db

# Feature flags
STELLAR_HEALTH_CHECK=true
JSON_PAYLOAD_LIMIT=1mb

# CORS
# Comma-separated list of allowed origins in staging/production.
# Falls back to * when NODE_ENV=development or this is not set.
ALLOWED_ORIGINS=

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60

# Auth-specific rate limiting (brute-force protection on /auth/challenge and /auth/token)
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=5

# Webhooks
WEBHOOK_ENABLED=false
WEBHOOK_URL=

# Security headers
SECURITY_HSTS=max-age=31536000; includeSubDomains
SECURITY_X_CONTENT_TYPE_OPTIONS=nosniff
SECURITY_X_FRAME_OPTIONS=DENY
SECURITY_REFERRER_POLICY=no-referrer

# API versioning
API_PREFIX=/api
API_V=v1

# Metrics
METRICS_ENABLED=false

# Milestone rate limiting
MILESTONE_RATE_WINDOW_MS=60000
MILESTONE_RATE_MAX=10

# Redis (optional — used for distributed caching)
REDIS_URL=

# Proxy
TRUSTED_PROXY_COUNT=0